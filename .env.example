# ─── Agent Forge environment ───────────────────────────────────────────────
# Copy to .env.local and fill in.

# REQUIRED — text/data/skill generation (the agent brain)
ANTHROPIC_API_KEY=sk-ant-...
# Optional: override the model used for generation
ANTHROPIC_MODEL=claude-sonnet-4-5

# OPTIONAL but recommended — competitor research for the business plan generator.
# Tavily-first (same provider as the debate-fact-checker project), Serper fallback,
# then DuckDuckGo Instant if neither key is set. Without a key the agent still writes
# the competitor analysis but with weaker, link-only signal.
TAVILY_API_KEY=
SERPER_API_KEY=

# OPTIONAL but recommended — visual asset generation (Nano Banana / Gemini)
# Without this, agents still generate full text + skill files; emblem/portrait/icon
# fall back to a generated placeholder glyph.
GEMINI_API_KEY=
# Nano Banana model. Pro = highest fidelity (2K), Flash = faster.
GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview
GEMINI_IMAGE_SIZE=2K

# OPTIONAL — image post-processing (background removal). Auto-detected if present.
# Path to a Python venv with `rembg` + `Pillow` installed (for emblem/icon transparency).
# Defaults to the repo's shared rembg venv if reachable.
REMBG_PYTHON=
# Near-white fuzz for ImageMagick glyph-hole cleanup (icons).
ICON_WHITE_FUZZ=14%
# Emblem pipeline: classic (default) = rembg + 14% white key + PIL trim — May 2026 look with glow.
# sharp = magick-only defringe (2–3% white key); set EMBLEM_WHITE_FUZZ=2% when using sharp.
EMBLEM_PIPELINE=classic
EMBLEM_WHITE_FUZZ=14%
EMBLEM_USE_REMBG=1
# Skip rembg when trim bbox shrinks below this fraction of raw (prevents center-sculpture crop).
EMBLEM_REMBG_MIN_RATIO=0.72
EMBLEM_MARGIN_PCT=5
# Sharp pipeline only (EMBLEM_PIPELINE=sharp):
# EMBLEM_SHARP_WHITE_FUZZ=2%
# EMBLEM_POST_WHITE_FUZZ=3%
# EMBLEM_ALPHA_THRESHOLD=65%
