# ─── Agent Forge environment ───────────────────────────────────────────────
# Copy to .env.local and fill in.

# Text LLM provider (default: OpenAI). Set FORGE_LLM_FALLBACK_PROVIDER=anthropic to
# retry with Claude when OpenAI fails (billing, rate limits, etc.).
FORGE_LLM_PROVIDER=openai
# FORGE_LLM_FALLBACK_PROVIDER=anthropic

# REQUIRED for default provider — text/data/skill generation (the agent brain)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.4-nano

# OPTIONAL — Anthropic fallback / legacy provider
# FORGE_LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5

# Retry / rate-limit resilience (AWS-style full jitter for direct clients; AI SDK handles backoff internally)
# ToolLoopAgent per-HTTP-call retries (default 6 → 7 attempts; SDK default is 2). Honors Retry-After 0–60s.
FORGE_ANTHROPIC_MAX_RETRIES=6
FORGE_OPENAI_MAX_RETRIES=6
# Direct @anthropic-ai/sdk calls (forge example generator). Defaults to FORGE_ANTHROPIC_MAX_RETRIES.
# FORGE_ANTHROPIC_CLIENT_MAX_RETRIES=6
# Gemini image generateContent retries (full jitter, base 1s, cap 60s).
FORGE_GEMINI_MAX_RETRIES=5
# Shared backoff tuning for Gemini (and any future direct HTTP retries).
# FORGE_RETRY_BASE_MS=1000
# FORGE_RETRY_CAP_MS=60000

# Proactive OpenAI TPM pacing + app-level rate-limit retries (ToolLoopAgent + generateObject).
# Soft cap on estimated tokens per rolling 60s window (0 = disable proactive throttle).
# FORGE_LLM_TPM_BUDGET=180000
# Minimum pause between LLM steps within a run (ms).
# FORGE_LLM_MIN_STEP_MS=400
# Extra retries when OpenAI returns rate_limit_exceeded / TPM (beyond AI SDK maxRetries).
# FORGE_LLM_RATE_LIMIT_RETRIES=8
# After success, decay pressure backoff by this percent (default 55 → multiply by 0.55).
# FORGE_LLM_BACKOFF_DECAY_PERCENT=55
# Estimated output tokens reserved per agent step for TPM budgeting.
# FORGE_LLM_STEP_OUTPUT_ESTIMATE=8000

# OPTIONAL but recommended — competitor research for the business plan generator.
# Tavily-first (same provider as the debate-fact-checker project), Serper fallback,
# then DuckDuckGo Instant if neither key is set. Without a key the agent still writes
# the competitor analysis but with weaker, link-only signal.
TAVILY_API_KEY=
SERPER_API_KEY=

# OPTIONAL but recommended — visual asset generation (Nano Banana / Gemini)
# Without this, agents still generate full text + skill files; emblem/portrait/icon
# fall back to a generated placeholder glyph.
GEMINI_API_KEY=
# Nano Banana model. Pro = highest fidelity (2K), Flash = faster.
GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview
GEMINI_IMAGE_SIZE=2K

# OPTIONAL — image post-processing (background removal). Auto-detected if present.
# Path to a Python venv with `rembg` + `Pillow` installed (for emblem/icon transparency).
# Defaults to the repo's shared rembg venv if reachable.
REMBG_PYTHON=
# Near-white fuzz for ImageMagick glyph-hole cleanup (icons).
ICON_WHITE_FUZZ=14%
# Emblem pipeline: classic (default) = rembg + 14% white key + PIL trim — May 2026 look with glow.
# sharp = magick-only defringe (2–3% white key); set EMBLEM_WHITE_FUZZ=2% when using sharp.
EMBLEM_PIPELINE=classic
EMBLEM_WHITE_FUZZ=14%
EMBLEM_USE_REMBG=1
# Skip rembg when trim bbox shrinks below this fraction of raw (prevents center-sculpture crop).
EMBLEM_REMBG_MIN_RATIO=0.72
EMBLEM_BBOX_PAD_PCT=8
EMBLEM_MARGIN_PCT=8
# Sharp pipeline only (EMBLEM_PIPELINE=sharp):
# EMBLEM_SHARP_WHITE_FUZZ=2%
# EMBLEM_POST_WHITE_FUZZ=3%
# EMBLEM_ALPHA_THRESHOLD=65%
# Business plaque transparency: same rembg + ImageMagick trick as icons/emblems,
# but magenta chroma key instead of white (white fuzz eats silver gunmetal).
PLAQUE_CHROMA_COLOR=#FF00FF
PLAQUE_CHROMA_FUZZ=12%
